#!/bin/bash
set -Eeuo pipefail

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}====================================================${NC}"
echo -e "${GREEN}   Tailscale & 1Panel 兼容版 交互式工具 (已修正)   ${NC}"
echo -e "${BLUE}====================================================${NC}"

if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}错误: 请使用 root 用户或 sudo 运行此脚本！${NC}"
    exit 1
fi

confirm_step() {
    local msg="$1"
    while true; do
        echo -e "\n${YELLOW}👉 [请确认] $msg${NC}"
        read -p "已经准备好了吗？(y/n): " choice
        case "$choice" in
            [Yy]* ) break;;
            [Nn]* ) echo -e "${RED}建议先完成配置，按任意键重新确认...${NC}"; read -n 1;;
            * ) echo "请输入 y 或 n。";;
        esac
    done
}

install_tailscale() {
    echo -e "\n${BLUE}正在检查并安装 Tailscale...${NC}"
    if ! command -v tailscale &> /dev/null; then
        curl -fsSL https://tailscale.com/install.sh | sh
    fi
    echo -e "${YELLOW}正在启动 Tailscale，请在浏览器中完成登录绑定...${NC}"
    tailscale up
    echo -e "${GREEN}Tailscale 组网成功！当前 IP: ${YELLOW}$(tailscale ip -4)${NC}"
}

deploy_derp_1panel() {
    echo -e "\n${BLUE}====================================================${NC}"
    echo -e "${GREEN}          准备进入 1Panel 联动 DERP 部署流程          ${NC}"
    echo -e "${BLUE}====================================================${NC}"
    
    confirm_step "你已经在 1Panel 创建了网站，配置好 HTTPS 证书，并设定代理地址为 127.0.0.1:3443 了吗？"

    read -p "请输入你的 DERP 域名 (例如 ts.52zy.eu.org): " DERP_DOMAIN
    
    echo -e "\n${BLUE}正在清理旧容器并启动新 DERP 容器...${NC}"
    docker rm -f derper &> /dev/null

    # 核心修复：纯 HTTP 模式，不验证客户端，适配 1Panel 反代
    docker run -d \
      --name derper \
      --restart=always \
      -p 3443:443 \
      -p 3478:3478/udp \
      fredliang/derper:latest \
      /app/derper \
      --hostname="${DERP_DOMAIN}" \
      --certmode=manual \
      --http-port=443 \
      --stun=true

    local my_ip
    my_ip=$(curl -s 4.ipw.cn || echo "")

    echo -e "\n${GREEN}====================================================${NC}"
    echo -e "${GREEN}🎉 容器已启动 (Up)，正在监听 3443/443 和 3478/udp${NC}"
    echo -e "${YELLOW}请将以下 JSON 复制到 Tailscale 控制台的 Access Control：${NC}"
    echo -e "${GREEN}====================================================${NC}"
    cat <<EOF
"derpMap": {
    "OmitDefaultRegions": true,
    "Regions": {
        "901": {
            "RegionID": 901,
            "RegionCode": "vps-1panel-derp",
            "RegionName": "1Panel Managed DERP",
            "Nodes": [
                {
                    "Name": "node-1",
                    "RegionID": 901,
                    "HostName": "${DERP_DOMAIN}",
                    "derpPort": 443
                }
            ]
        }
    }
},
EOF
}

# 菜单入口
echo -e "${YELLOW}请选择操作：${NC}"
echo -e " [1] 安装 Tailscale"
echo -e " [2] 安装 Tailscale 并部署 DERP (联动 1Panel)"
echo -e " [3] 彻底清理"
read -p "请输入数字: " ROLE

case "$ROLE" in
    1) install_tailscale ;;
    2) install_tailscale; deploy_derp_1panel ;;
    3) echo "清理逻辑请参考原脚本";;
    *) exit 1 ;;
esac
